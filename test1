<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Work Record Dashboard</title>
<style>
:root {
  --bg:#f8fafc;
  --bg2:#eef4f8;
  --panel:rgba(255,255,255,.97);
  --line:#dbe4ee;
  --text:#1f2937;
  --muted:#667085;
  --accent:#3b82f6;
  --shadow:0 18px 40px rgba(15,23,42,.06);
  --radius:24px;
}
* { box-sizing:border-box; }
html,body { margin:0; padding:0; }
body {
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  color:var(--text);
  background:
    radial-gradient(circle at top left, rgba(59,130,246,.06), transparent 24%),
    linear-gradient(180deg, #ffffff 0%, var(--bg) 55%, var(--bg2) 100%);
}
.container { width:min(1320px, calc(100% - 32px)); margin:0 auto; padding:28px 0 56px; }
.hero {
  position:sticky; top:0; z-index:20; padding:4px 0 18px;
  backdrop-filter:blur(14px);
  background:linear-gradient(180deg, rgba(248,250,252,.96), rgba(248,250,252,.78) 80%, rgba(248,250,252,0));
}
.surface {
  background:var(--panel);
  border:1px solid var(--line);
  border-radius:28px;
  box-shadow:var(--shadow);
}
.hero-card { padding:22px 24px; }
h1 { margin:0; font-size:clamp(1.75rem,2.5vw,2.55rem); letter-spacing:-.03em; }

.year-select-wrap { display:flex; align-items:center; gap:12px; margin-top:16px; }
.year-select-label { font-size:13px; font-weight:700; color:#64748b; letter-spacing:.02em; }
.year-select {
  appearance:none;
  background:#fff;
  border:1px solid #d6deeb;
  border-radius:12px;
  padding:10px 38px 10px 14px;
  font:600 14px Inter;
  min-width:120px;
}

.section { margin-top:20px; }
.grid { display:grid; gap:18px; }
.kpis { grid-template-columns:repeat(4,minmax(0,1fr)); }

.kpi { padding:22px; }

.two-up {
  grid-template-columns:minmax(0,1.15fr) minmax(320px,.85fr);
}

.panel { padding:22px; }

.volume-list { display:grid; gap:12px; }

.bar-track {
  height:12px;
  background:#ecf2f8;
  border-radius:999px;
}

.bar-fill {
  height:100%;
  background:linear-gradient(90deg,#93c5fd,#3b82f6);
}

.projects-head {
  display:flex;
  justify-content:space-between;
  margin-bottom:14px;
}

.cards {
  display:grid;
  gap:16px;
  grid-template-columns:repeat(2,minmax(0,1fr));
}

.card {
  padding:18px;
  border:1px solid #e5edf5;
  border-radius:14px;
  background:white;
}

.role-pill {
  padding:6px 10px;
  border-radius:999px;
  font-size:12px;
  font-weight:700;
}

.role-Translation {
  background:#eaf2ff;
  color:#2453b6;
}

.role-Proofreading {
  background:#f2ebff;
  color:#6d28d9;
}

.file-toggle {
  margin-top:12px;
  border:none;
  background:none;
  color:#2563eb;
  font-weight:700;
  cursor:pointer;
}

.file-list {
  display:none;
  margin-top:8px;
}

.file-list.open {
  display:block;
}
</style>
</head>

<body>

<div class="container">

<div class="hero">
<div class="surface hero-card">

<h1>Work Record Dashboard</h1>

<div class="year-select-wrap">
<label class="year-select-label">Year</label>
<select id="yearSelect"></select>
</div>

</div>
</div>

<section class="section grid kpis" id="kpiGrid"></section>

<section class="section grid two-up">

<div class="surface panel">

<h2>Volume</h2>

<div id="volumeChart"></div>

</div>

<div class="surface panel">

<h2>Category Breakdown</h2>

<div id="categoryBreakdown"></div>

</div>

</section>

<section class="section surface panel">

<div class="projects-head">

<h2>Projects</h2>

</div>

<div id="projects"></div>

</section>

</div>

<script>

const rows = [];

</script>

</body>

</html>
